<!--
  MikroTik RouterOS Wazuh Decoder
  https://github.com/H2FSpawn/wazuh-mikrotik-decoder

  Tested: RouterOS 7.x, Wazuh 4.12-4.14
  Syslog format: BSD (RFC 3164)

  Known limitations:
  - The "->" separator in RouterOS firewall logs is a reserved operator
    in Wazuh's regex engine and cannot be escaped. As a result, dstip
    and dstport cannot be extracted from firewall events.
    srcip and srcport are extracted via the "proto" field anchor.
  - TCP flag annotations like "(SYN)" or "(ACK)" in firewall logs
    prevent srcip/srcport extraction because Wazuh applies only the
    first matching decoder per event. Configure RouterOS firewall
    logging without TCP flags to ensure field extraction works.
    See docs/mikrotik-syslog-setup.md for the recommended configuration.
    Events still match and fire rules even without field extraction.
  - DHCP field extraction only works for "assigned" lease events.
    "offering" and other DHCP events match rule 110003 without fields.
  - Parent-child decoder structures are unreliable in this context.
    All decoders here are standalone.
-->

<!-- Firewall: extracts srcip and srcport via "proto" anchor -->
<!-- Note: TCP flag annotations (SYN/ACK) prevent field extraction. -->
<!-- Configure RouterOS without flags for reliable extraction.      -->
<decoder name="mikrotik-firewall">
  <prematch>firewall,</prematch>
  <regex>proto \S+, (\d+\.\d+\.\d+\.\d+):(\d+)</regex>
  <order>srcip, srcport</order>
</decoder>

<!-- DHCP: extracts assigned IP, MAC address, and client hostname -->
<decoder name="mikrotik-dhcp">
  <prematch>dhcp,</prematch>
  <regex>assigned (\d+\.\d+\.\d+\.\d+) to (\S+) \((\S+)\)</regex>
  <order>srcip, extra_data, hostname</order>
</decoder>

<!-- System: general RouterOS system messages, no field extraction -->
<decoder name="mikrotik-system">
  <prematch>system,</prematch>
</decoder>
